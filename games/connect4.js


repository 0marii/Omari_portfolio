'use strict';

/**
 * Connect 4 — board[row][col], row 0 = top, row 5 = bottom.
 * Player 1 = human (red), Player 2 = AI or friend (yellow).
 */

const ROWS = 6;
const COLS = 7;
const WIN_LEN = 4;

const modeScreen = document.getElementById('modeScreen');
const gameArea = document.getElementById('gameArea');
const statusMsg = document.getElementById('statusMsg');
const boardEl = document.getElementById('boardEl');
const btnAI = document.getElementById('btnAI');
const btnFriend = document.getElementById('btnFriend');
const newGameBtn = document.getElementById('newGameBtn');
const changeModeBtn = document.getElementById('changeModeBtn');
const hudP1 = document.getElementById('hudP1');
const hudP2 = document.getElementById('hudP2');
const hudOppLabel = document.getElementById('hudOppLabel');

let mode = null;
let board = null;
let current = 1;
let gameOver = false;
let wins = { p1: 0, p2: 0 };
let slotEls = [];

function loadWins() {
  try {
    wins.p1 = parseInt(localStorage.getItem('c4_w_p1') || '0', 10) || 0;
    wins.p2 = parseInt(localStorage.getItem('c4_w_p2') || '0', 10) || 0;
  } catch (_) {
    wins = { p1: 0, p2: 0 };
  }
  hudP1.textContent = String(wins.p1);
  hudP2.textContent = String(wins.p2);
}

function saveWins() {
  try {
    localStorage.setItem('c4_w_p1', String(wins.p1));
    localStorage.setItem('c4_w_p2', String(wins.p2));
  } catch (_) {}
}

function setGameFlag(on) {
  window.gameInProgress = !!on && !gameOver;
}

function buildBoardDom() {
  boardEl.textContent = '';
  slotEls = [];
  for (let c = 0; c < COLS; c++) {
    const col = document.createElement('div');
    col.className = 'c4-col';
    col.dataset.col = String(c);
    col.setAttribute('role', 'row');
    const slots = [];
    for (let r = 0; r < ROWS; r++) {
      const slot = document.createElement('div');
      slot.className = 'c4-slot';
      slot.dataset.r = String(r);
      slot.dataset.c = String(c);
      col.appendChild(slot);
      slots.push(slot);
    }
    slotEls.push(slots);
    boardEl.appendChild(col);
    col.addEventListener('click', () => onColumnClick(c));
    col.addEventListener('touchstart', (e) => {
      e.preventDefault();
      onColumnClick(c);
    }, { passive: false });
  }
}

function resetRound() {
  board = Array.from({ length: ROWS }, () => Array(COLS).fill(0));
  current = 1;
  gameOver = false;
  paintBoard();
  updateStatus();
  setGameFlag(true);
}

function paintBoard() {
  for (let r = 0; r < ROWS; r++) {
    for (let c = 0; c < COLS; c++) {
      const el = slotEls[c][r];
      el.classList.remove('p1', 'p2');
      const v = board[r][c];
      if (v === 1) el.classList.add('p1');
      else if (v === 2) el.classList.add('p2');
    }
  }
}

function lowestEmptyRow(col) {
  for (let r = ROWS - 1; r >= 0; r--) {
    if (board[r][col] === 0) return r;
  }
  return -1;
}

function winnerMove(player) {
  for (let r = 0; r < ROWS; r++) {
    for (let c = 0; c < COLS; c++) {
      if (board[r][c] !== player) continue;
      if (c <= COLS - WIN_LEN) {
        let ok = true;
        for (let k = 1; k < WIN_LEN; k++) {
          if (board[r][c + k] !== player) { ok = false; break; }
        }
        if (ok) return true;
      }
      if (r <= ROWS - WIN_LEN) {
        let ok = true;
        for (let k = 1; k < WIN_LEN; k++) {
          if (board[r + k][c] !== player) { ok = false; break; }
        }
        if (ok) return true;
      }
      if (r <= ROWS - WIN_LEN && c <= COLS - WIN_LEN) {
        let ok = true;
        for (let k = 1; k < WIN_LEN; k++) {
          if (board[r + k][c + k] !== player) { ok = false; break; }
        }
        if (ok) return true;
      }
      if (r <= ROWS - WIN_LEN && c >= WIN_LEN - 1) {
        let ok = true;
        for (let k = 1; k < WIN_LEN; k++) {
          if (board[r + k][c - k] !== player) { ok = false; break; }
        }
        if (ok) return true;
      }
    }
  }
  return false;
}

function boardFull() {
  for (let c = 0; c < COLS; c++) {
    if (board[0][c] === 0) return false;
  }
  return true;
}

function updateStatus() {
  statusMsg.classList.remove('s--p1', 's--p2', 's--win');
  if (gameOver) return;
  if (mode === 'ai') {
    if (current === 1) {
      statusMsg.textContent = 'Your turn — click a column';
      statusMsg.classList.add('s--p1');
    } else {
      statusMsg.textContent = 'AI is thinking…';
      statusMsg.classList.add('s--p2');
    }
  } else {
    if (current === 1) {
      statusMsg.textContent = 'Red\'s turn';
      statusMsg.classList.add('s--p1');
    } else {
      statusMsg.textContent = 'Yellow\'s turn';
      statusMsg.classList.add('s--p2');
    }
  }
}

function endGame(winner) {
  gameOver = true;
  setGameFlag(false);
  statusMsg.classList.remove('s--p1', 's--p2');
  statusMsg.classList.add('s--win');
  if (winner === 0) {
    statusMsg.textContent = 'Draw — board full';
    return;
  }
  if (winner === 1) {
    wins.p1++;
    statusMsg.textContent = mode === 'ai' ? 'You win! 🎉' : 'Red wins!';
  } else {
    wins.p2++;
    statusMsg.textContent = mode === 'ai' ? 'AI wins' : 'Yellow wins!';
  }
  saveWins();
  hudP1.textContent = String(wins.p1);
  hudP2.textContent = String(wins.p2);
}

function applyMove(col, player) {
  const r = lowestEmptyRow(col);
  if (r < 0) return false;
  board[r][col] = player;
  paintBoard();
  if (winnerMove(player)) {
    endGame(player);
    return true;
  }
  if (boardFull()) {
    endGame(0);
    return true;
  }
  current = player === 1 ? 2 : 1;
  updateStatus();
  return true;
}

/* ── Minimax AI (depth 6, alpha-beta, center bias) ───────── */

const COL_ORDER = [3, 2, 4, 1, 5, 0, 6];

function scoreWindow(a, b, c, d, ai) {
  const line = [a, b, c, d];
  const countAi = line.filter(x => x === ai).length;
  const countHum = line.filter(x => x === (3 - ai)).length;
  const countE = line.filter(x => x === 0).length;
  if (countHum > 0 && countAi > 0) return 0;
  if (countAi === 4) return 100000;
  if (countHum === 4) return -100000;
  if (countAi === 3 && countE === 1) return 50;
  if (countHum === 3 && countE === 1) return -120;
  if (countAi === 2 && countE === 2) return 8;
  if (countHum === 2 && countE === 2) return -10;
  return 0;
}

function evaluateBoard(b, ai) {
  let s = 0;
  for (let r = 0; r < ROWS; r++) {
    for (let c = 0; c < COLS - 3; c++) {
      s += scoreWindow(b[r][c], b[r][c + 1], b[r][c + 2], b[r][c + 3], ai);
    }
  }
  for (let c = 0; c < COLS; c++) {
    for (let r = 0; r < ROWS - 3; r++) {
      s += scoreWindow(b[r][c], b[r + 1][c], b[r + 2][c], b[r + 3][c], ai);
    }
  }
  for (let r = 0; r < ROWS - 3; r++) {
    for (let c = 0; c < COLS - 3; c++) {
      s += scoreWindow(b[r][c], b[r + 1][c + 1], b[r + 2][c + 2], b[r + 3][c + 3], ai);
      s += scoreWindow(b[r][c + 3], b[r + 1][c + 2], b[r + 2][c + 1], b[r + 3][c], ai);
    }
  }
  for (let c = 0; c < COLS; c++) {
    const colArr = [];
    for (let r = 0; r < ROWS; r++) colArr.push(b[r][c]);
    const base = [0, 2, 4, 6, 8, 10][c];
    s += colArr.filter((v) => v === ai).length * base;
    s -= colArr.filter((v) => v === 3 - ai).length * base;
  }
  return s;
}

function copyBoard(b) {
  return b.map((row) => row.slice());
}

function minimax(b, depth, alpha, beta, maximizing, ai) {
  const hu = 3 - ai;
  if (winnerMove(ai)) return { score: 500000 + depth, col: -1 };
  if (winnerMove(hu)) return { score: -500000 - depth, col: -1 };
  if (boardFullSim(b)) return { score: 0, col: -1 };
  if (depth === 0) return { score: evaluateBoard(b, ai), col: -1 };

  if (maximizing) {
    let best = -1e9;
    let bestCol = -1;
    for (const c of COL_ORDER) {
      const r = lowestEmptyRowSim(b, c);
      if (r < 0) continue;
      b[r][c] = ai;
      const sc = minimax(b, depth - 1, alpha, beta, false, ai).score;
      b[r][c] = 0;
      if (sc > best) {
        best = sc;
        bestCol = c;
      }
      alpha = Math.max(alpha, sc);
      if (beta <= alpha) break;
    }
    return { score: best, col: bestCol };
  }

  let best = 1e9;
  let bestCol = -1;
  for (const c of COL_ORDER) {
    const r = lowestEmptyRowSim(b, c);
    if (r < 0) continue;
    b[r][c] = hu;
    const sc = minimax(b, depth - 1, alpha, beta, true, ai).score;
    b[r][c] = 0;
    if (sc < best) {
      best = sc;
      bestCol = c;
    }
    beta = Math.min(beta, sc);
    if (beta <= alpha) break;
  }
  return { score: best, col: bestCol };
}

function lowestEmptyRowSim(b, col) {
  for (let r = ROWS - 1; r >= 0; r--) {
    if (b[r][col] === 0) return r;
  }
  return -1;
}

function boardFullSim(b) {
  for (let c = 0; c < COLS; c++) {
    if (b[0][c] === 0) return false;
  }
  return true;
}

function winnerMoveSim(b, player) {
  for (let r = 0; r < ROWS; r++) {
    for (let c = 0; c < COLS; c++) {
      if (b[r][c] !== player) continue;
      if (c <= COLS - WIN_LEN) {
        let ok = true;
        for (let k = 1; k < WIN_LEN; k++) {
          if (b[r][c + k] !== player) { ok = false; break; }
        }
        if (ok) return true;
      }
      if (r <= ROWS - WIN_LEN) {
        let ok = true;
        for (let k = 1; k < WIN_LEN; k++) {
          if (b[r + k][c] !== player) { ok = false; break; }
        }
        if (ok) return true;
      }
      if (r <= ROWS - WIN_LEN && c <= COLS - WIN_LEN) {
        let ok = true;
        for (let k = 1; k < WIN_LEN; k++) {
          if (b[r + k][c + k] !== player) { ok = false; break; }
        }
        if (ok) return true;
      }
      if (r <= ROWS - WIN_LEN && c >= WIN_LEN - 1) {
        let ok = true;
        for (let k = 1; k < WIN_LEN; k++) {
          if (b[r + k][c - k] !== player) { ok = false; break; }
        }
        if (ok) return true;
      }
    }
  }
  return false;
}

function aiTurn() {
  if (gameOver || current !== 2 || mode !== 'ai') ret;
}
